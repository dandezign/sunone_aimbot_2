{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "figma": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "figma-developer-mcp",
        "--stdio"
      ],
      "environment": {
        "FIGMA_API_KEY": "YOUR_FIGMA_API_KEY_HERE"
      },
      "enabled": true,
      "timeout": 15000
    }
  }
}